# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentic_commerce
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:8081

# Anthropic (Claude AI)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Google Custom Search API
# 1. Get API key from: https://console.cloud.google.com/apis/credentials
# 2. Get Search Engine ID from: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# SerpAPI - Primary search provider (used instead of Google Custom Search if set)
# Get API key from: https://serpapi.com/
SERPAPI_KEY=your-serpapi-key-here

# RapidAPI - Flight search (runs in parallel with SerpAPI)
# Get API key from: https://rapidapi.com/kevinagustiansyah298-RSbcaTc-IDi/api/sky-scrapper3
RAPIDAPI_KEY=your-rapidapi-key-here
# Optional: Override host (default: sky-scrapper3.p.rapidapi.com). Use sky-scrapper.p.rapidapi.com for original Sky Scrapper
# RAPIDAPI_HOST=sky-scrapper.p.rapidapi.com

# Card MCP (Streamable HTTP) — backend proxies POST /api/mcp/evaluate-payment-options
# Register: POST http://cardsmcpserver-production.up.railway.app/api/keys/register
CARD_MCP_SERVER_URL=http://cardsmcpserver-production.up.railway.app/mcp
MCP_API_TOKEN=your-cmcp_sk-or-bearer-token
# Default Rewards Optimizer toolset (omit to expose every tool your tier allows)
CARD_MCP_TOOLSET_ID=agent-default_optimizer
# Optional: send token as X-API-Key instead of Authorization Bearer
# CARD_MCP_AUTH=x-api-key
# Alternative env name for toolset id: MCP_TOOLSET_ID

# SMTP (Password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AgenticCommerce <noreply@agenticcommerce.com>

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60
ADMIN_PORTAL_URL=http://localhost:3000/admin
