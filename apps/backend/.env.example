# Server Configuration
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentic_commerce
REDIS_URL=redis://localhost:6379

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Payment Gateway Configuration
# Supported gateways: stripe, razorpay, paypal, square
PAYMENT_GATEWAY=stripe

# Payment Gateway Credentials
# For Stripe:
#   PAYMENT_API_KEY = Secret Key (sk_test_xxxxx)
# For Razorpay:
#   PAYMENT_API_KEY = Key ID (rzp_test_xxxxx)
#   PAYMENT_API_SECRET = Key Secret
# For PayPal:
#   PAYMENT_API_KEY = Client ID
#   PAYMENT_API_SECRET = Client Secret
# For Square:
#   PAYMENT_API_KEY = Access Token

PAYMENT_API_KEY=your_payment_api_key
PAYMENT_API_SECRET=your_payment_api_secret
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# Legacy Stripe Configuration (for backward compatibility)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# MCP Configuration
MCP_SERVER_URLS=http://localhost:8080/mcp

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
