# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentic_commerce
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:8081

# Anthropic (Claude AI)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Google Custom Search API
# 1. Get API key from: https://console.cloud.google.com/apis/credentials
# 2. Get Search Engine ID from: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# SerpAPI - Primary search provider (used instead of Google Custom Search if set)
# Get API key from: https://serpapi.com/
SERPAPI_KEY=your-serpapi-key-here

# RapidAPI - Flight search fallback when SerpAPI returns no results
# Get API key from: https://rapidapi.com/sky-scrapper/api/sky-scrapper or sky-scrapper3
RAPIDAPI_KEY=your-rapidapi-key-here
# Optional: Override host for sky-scrapper3 or other providers (default: sky-scrapper.p.rapidapi.com)
# RAPIDAPI_HOST=sky-scrapper3.p.rapidapi.com
