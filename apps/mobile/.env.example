# Backend API
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Payment Gateway
# Options: stripe, razorpay, paypal, square
EXPO_PUBLIC_PAYMENT_GATEWAY=stripe

# Payment Gateway Publishable Keys (use based on selected gateway)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
EXPO_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
EXPO_PUBLIC_SQUARE_APPLICATION_ID=your_square_app_id
