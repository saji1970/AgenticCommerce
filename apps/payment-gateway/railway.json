{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/payment-gateway/Dockerfile",
    "dockerContext": "apps/payment-gateway",
    "watchPatterns": ["apps/payment-gateway/**"]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
