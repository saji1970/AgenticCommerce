# Environment
NODE_ENV=development

# Backend API
PORT=3000
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentic_commerce
REDIS_URL=redis://localhost:6379

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Payment Gateway Configuration
# Options: stripe, razorpay, paypal, square
PAYMENT_GATEWAY=stripe

# Payment Gateway Credentials (use based on selected gateway)
PAYMENT_API_KEY=your_payment_api_key
PAYMENT_API_SECRET=your_payment_api_secret  # Required for Razorpay, PayPal, Square
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# Legacy Stripe Variables (for backward compatibility)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Product Search Configuration
# Options: rapidapi, serpapi, mcp
PRODUCT_DATA_SOURCE=rapidapi

# RapidAPI (Recommended for MVP - Free tier: 100 requests/month)
RAPIDAPI_KEY=your_rapidapi_key

# SerpAPI (Alternative - Free tier: 100 searches/month)
SERPAPI_KEY=your_serpapi_key

# MCP Servers (Advanced - comma-separated URLs)
# Only needed if PRODUCT_DATA_SOURCE=mcp
MCP_SERVER_URLS=http://retailer1.mcp.example.com,http://retailer2.mcp.example.com

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Mobile App (for .env in apps/mobile)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_PAYMENT_GATEWAY=stripe
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
